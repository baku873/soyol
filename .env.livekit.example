# =============================================================================
# LiveKit Video Call System — Required Environment Variables
# =============================================================================

# LiveKit API Key (server-only — used for token generation and room management)
LIVEKIT_API_KEY=your-livekit-api-key

# LiveKit API Secret (server-only — used for signing access tokens)
LIVEKIT_API_SECRET=your-livekit-api-secret

# LiveKit WebSocket URL (server-only — used by RoomServiceClient for REST calls)
# This is the same URL but used server-side; converted to https:// internally
LIVEKIT_URL=wss://your-project.livekit.cloud

# LiveKit WebSocket URL (browser-exposed — used by livekit-client to connect)
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# =============================================================================
# Existing project env vars (see .env for full list)
# =============================================================================
# MONGODB_URI=...
# JWT_SECRET=...
# etc.
